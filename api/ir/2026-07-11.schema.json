{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gwai.dev/schema/ir/2026-07-11",
  "title": "gwai generation IR 2026-07-11",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/response" }
  ],
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_id", "upstream_model"],
      "properties": {
        "provider_id": { "type": "string", "minLength": 1 },
        "upstream_model": { "type": "string", "minLength": 1 }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "media_type": {
          "enum": ["image/jpeg", "image/png", "image/gif", "image/webp"]
        },
        "data": { "type": "string", "contentEncoding": "base64" }
      },
      "oneOf": [
        { "required": ["url"] },
        { "required": ["media_type", "data"] }
      ]
    },
    "textContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "text" },
        "text": { "type": "string" }
      }
    },
    "imageContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "image"],
      "properties": {
        "type": { "const": "image" },
        "image": { "$ref": "#/$defs/image" }
      }
    },
    "toolCallContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_call"],
      "properties": {
        "type": { "const": "tool_call" },
        "tool_call": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "arguments"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "arguments": true
          }
        }
      }
    },
    "toolResultContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "tool_result"],
      "properties": {
        "type": { "const": "tool_result" },
        "tool_result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tool_call_id", "content"],
          "properties": {
            "tool_call_id": { "type": "string", "minLength": 1 },
            "content": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "$ref": "#/$defs/textContent" },
                  { "$ref": "#/$defs/imageContent" }
                ]
              }
            },
            "is_error": { "type": "boolean" }
          }
        }
      }
    },
    "content": {
      "oneOf": [
        { "$ref": "#/$defs/textContent" },
        { "$ref": "#/$defs/imageContent" },
        { "$ref": "#/$defs/toolCallContent" },
        { "$ref": "#/$defs/toolResultContent" }
      ]
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "content"],
      "properties": {
        "role": { "enum": ["system", "user", "assistant", "tool"] },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/content" }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "input_schema"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "input_schema": { "type": "object" },
        "strict": { "type": "boolean" }
      }
    },
    "toolChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["auto", "none", "required", "named"] },
        "name": { "type": "string", "minLength": 1 },
        "disable_parallel": { "type": "boolean" }
      },
      "if": {
        "properties": { "mode": { "const": "named" } },
        "required": ["mode"]
      },
      "then": { "required": ["name"] }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "id",
        "route",
        "messages"
      ],
      "properties": {
        "version": { "const": "2026-07-11" },
        "id": { "type": "string", "minLength": 1 },
        "route": { "$ref": "#/$defs/route" },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/message" }
        },
        "max_output_tokens": { "type": "integer", "minimum": 1 },
        "temperature": { "type": "number", "minimum": 0 },
        "top_p": { "type": "number", "minimum": 0, "maximum": 1 },
        "stop": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/tool" }
        },
        "tool_choice": { "$ref": "#/$defs/toolChoice" },
        "metadata": { "type": "object" },
        "stream": { "type": "boolean" }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cached_input_tokens": { "type": "integer", "minimum": 0 }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "id",
        "model",
        "content",
        "finish_reason",
        "usage"
      ],
      "properties": {
        "version": { "const": "2026-07-11" },
        "id": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "content": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/textContent" },
              { "$ref": "#/$defs/toolCallContent" }
            ]
          }
        },
        "finish_reason": {
          "enum": ["stop", "length", "tool_calls", "content_filter"]
        },
        "stop_sequence": { "type": "string" },
        "usage": { "$ref": "#/$defs/usage" },
        "provider_response_id": { "type": "string" }
      }
    }
  }
}
